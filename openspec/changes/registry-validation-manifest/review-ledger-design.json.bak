{
  "feature_id": "registry-validation-manifest",
  "phase": "design",
  "current_round": 1,
  "status": "has_open_high",
  "max_finding_id": 3,
  "findings": [
    {
      "id": "R1-F01",
      "severity": "high",
      "category": "completeness",
      "title": "Registry completeness is not actually validated against the filesystem",
      "detail": "The design relies on a manual registry plus a `file-exists` checker, but that only proves registered paths exist. It does not catch the acceptance-criteria failure where a real asset exists on disk but is missing from the registry. As written, the design cannot enforce that every `global/commands/*.md`, every `global/prompts/*.md`, and every executable in `bin/` has a corresponding registry entry. Add a completeness checker that scans those locations and compares them to the registry, failing on missing or extra entries.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    },
    {
      "id": "R1-F02",
      "severity": "medium",
      "category": "consistency",
      "title": "`handoffTargets` and `agentRoles` are modeled inconsistently between the design, types, and tasks",
      "detail": "The design says commands, prompts, orchestrators, handoff targets, and agent roles are all asset types and the manifest must expose top-level `handoffTargets` and `agentRoles`, but the task list only creates registry entries for commands/prompts/orchestrators and treats handoff targets and agent roles as references on commands. That leaves the required manifest sections underspecified and does not resolve how these asset types satisfy the common entry contract (`id`, `type`, `filePath`, `references`). Pick one concrete model for these two groups and align `types.ts`, `registry.ts`, validation rules, and manifest generation tasks to that model.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    },
    {
      "id": "R1-F03",
      "severity": "medium",
      "category": "completeness",
      "title": "The modified `openspec validate` requirement is only checked, not implemented",
      "detail": "Task 4.6 adds a syntax checker, but there is no task to update the existing command files that must comply with the modified spec. In the current repository, `global/commands/specflow.design.md` still validates through `specflow-design-artifacts validate <CHANGE_ID>` instead of `openspec validate \"<CHANGE_ID>\" --type change --json`, so the acceptance criterion cannot pass without explicit source edits. Add tasks to patch the affected command markdown files before or alongside the new checker.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    }
  ],
