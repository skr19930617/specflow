{
  "feature_id": "bash-orchestrator-extraction",
  "phase": "design",
  "current_round": 1,
  "status": "in_progress",
  "max_finding_id": 3,
  "findings": [
    {
      "id": "R1-F01",
      "severity": "medium",
      "category": "completeness",
      "file": "design.md",
      "title": "Divergence and next-action rules are not specified",
      "detail": "The proposal explicitly includes divergence detection and next-action branching in the control flow to extract, but the design only introduces action/handoff fields and a task for divergence warnings. It never defines what counts as divergence, when the loop should continue vs stop, or how status, action, and handoff are derived from those states. Add an explicit decision table and matching implementation/test tasks so the Bash orchestrator can reproduce the current behavior deterministically.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    },
    {
      "id": "R1-F02",
      "severity": "medium",
      "category": "consistency",
      "file": "design.md",
      "title": "Script entrypoint contract is internally inconsistent",
      "detail": "Decision D1 commits to three subcommands (review, fix-review, autofix-loop), but Task 1.2 describes parsing CHANGE_ID, --max-rounds, and an --autofix flag alongside subcommand dispatch. Settle on one internal CLI shape and update the task list and tests to match it; otherwise wrapper integration and test fixtures will be built against an unstable contract.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    },
    {
      "id": "R1-F03",
      "severity": "medium",
      "category": "risk",
      "file": "design.md",
      "title": "Codex parse-failure handling is not broken down into implementable work",
      "detail": "The design identifies codex JSON parse failures as a key runtime risk and proposes skip/abort behavior, but the task list has no explicit work for parse validation, consecutive-failure tracking, error/result JSON population, or bats coverage for those paths. Add concrete tasks and tests for initial review, re-review, and auto-fix-loop failure handling so the main orchestration boundary is defined rather than left implicit.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    }
  ],
