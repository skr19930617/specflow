{
  "feature_id": "move-proposal-source-normalization-to-runtime",
  "phase": "proposal",
  "current_round": 2,
  "status": "in_progress",
  "max_finding_id": 3,
  "findings": [
    {
      "id": "R1-F01",
      "severity": "medium",
      "category": "completeness",
      "file": "proposal.md",
      "title": "CLI contract matrix and failure behavior are not defined",
      "detail": "The proposal changes `specflow-prepare-change` from a single `--source-file` contract to a mixed positional/deprecated-flag contract, but it does not say what happens when callers provide both inputs, neither input, multiple positional values, an invalid GitHub issue URL, or a fetch failure. Those cases determine parser design, validation rules, migration behavior, and acceptance tests. Add explicit acceptance criteria for each supported and rejected invocation shape, precedence rules, exit/error behavior, and whether deprecated `--source-file` emits warnings.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "open",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    },
    {
      "id": "R1-F02",
      "severity": "medium",
      "category": "clarity",
      "file": "proposal.md",
      "title": "Auto-detection scope is too vague to design safely",
      "detail": "`matches a GitHub issue URL pattern` does not define the supported input boundary. It is unclear whether the new contract accepts only full GitHub issue URLs, also GitHub Enterprise domains, pull request URLs, issue comments, or shorthand references, and how inline text containing URLs should be handled. Define the exact supported patterns and explicit non-goals so the parser and `specflow-fetch-issue` integration do not drift.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "resolved",
      "relation": "new",
      "supersedes": null,
      "notes": "",
      "resolved_round": 2
    },
    {
      "id": "R1-F03",
      "severity": "medium",
      "category": "consistency",
      "file": "proposal.md",
      "title": "Breaking-change classification conflicts with the stated compatibility story",
      "detail": "The change is marked `BREAKING`, but the proposal also says `--source-file` is retained for backward compatibility and `specflow-fetch-issue` is unchanged. That leaves rollout expectations unclear for design and validation: is this an additive contract with deprecation, or an immediate breaking migration? Reconcile the classification and state how both invocation forms should appear in command contracts, docs, and transition tests until the deprecated path is removed.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "resolved",
      "relation": "new",
      "supersedes": null,
      "notes": "",
      "resolved_round": 2
    }
  ],
