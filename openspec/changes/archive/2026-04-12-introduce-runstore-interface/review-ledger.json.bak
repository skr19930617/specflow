    },
    {
      "id": "R1-F02",
      "severity": "medium",
      "category": "correctness",
      "file": "src/lib/local-fs-run-artifact-store.ts",
      "title": "RunArtifactStore.list() does not implement the lexicographic ordering guarantee",
      "detail": "In `list()`, the LocalFs store returns raw `readdirSync(runsDir)` order and never sorts the entries before returning refs. The spec makes lexicographic `runId` ordering an explicit store guarantee, and the new `artifact-store.test.ts` assertions rely on that contract. This only passes locally because the filesystem happens to return a favorable order; sort `entries` or the final refs by `runId` before returning to make the behavior deterministic.",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    }
