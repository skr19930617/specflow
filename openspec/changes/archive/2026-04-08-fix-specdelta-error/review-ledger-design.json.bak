{
  "feature_id": "fix-specdelta-error",
  "phase": "design",
  "current_round": 1,
  "status": "has_open_high",
  "max_finding_id": 2,
  "findings": [
    {
      "id": "R1-F01",
      "severity": "high",
      "category": "completeness",
      "title": "Fallback spec generation is undefined for the primary zero-spec case",
      "detail": "The design says to fall back to the format of existing `openspec/specs/*/spec.md` files and assumes `openspec new spec` can create the target structure, but the target scenario is precisely repositories with no baseline specs. If OpenSpec CLI does not provide a usable spec template/create path, implementers have no defined output contract, so acceptance criteria 3, 4, and 6 are not reliably satisfiable. Define a canonical fallback spec template/schema that is known to work with downstream `/specflow`, specify a direct file/directory creation path when CLI support is absent, and normalize/deduplicate capability names before writing `openspec/specs/<name>/spec.md`.",
      "file": "design.md",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    },
    {
      "id": "R1-F02",
      "severity": "medium",
      "category": "completeness",
      "title": "The `/specflow` handoff checks directories instead of usable spec files",
      "detail": "Task 2.1 checks the number of directories under `openspec/specs/`, but the actual failure mode is the absence of valid baseline spec files. A missing `openspec/specs/` directory, empty capability directories, or directories without `spec.md` would incorrectly bypass the handoff and still fail later. Change the condition to require at least one valid `openspec/specs/*/spec.md` file, and treat missing or empty directories the same way for the AskUserQuestion prompt.",
      "file": "tasks.md",
      "origin_round": 1,
      "latest_round": 1,
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "notes": ""
    }
  ],
