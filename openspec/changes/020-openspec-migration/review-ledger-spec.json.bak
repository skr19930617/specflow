{
  "feature_id": "020-openspec-migration",
  "phase": "spec",
  "current_round": 1,
  "status": "has_open_high",
  "max_finding_id": 3,
  "findings": [
    {
      "id": "R1-F01",
      "severity": "medium",
      "category": "scope",
      "file": "spec.md",
      "title": "Install/init and template scope conflicts with the issue",
      "detail": "The issue explicitly includes reworking the README/setup flow, clarifying what gets copied into user projects, and simplifying specflow-install / specflow-init. The spec instead says downstream install/init changes are out of scope and assumes template/ continues unchanged. That leaves implementation scope unclear: should this migration actually change install/init behavior and bootstrap assets now, or only document them?",
      "suggested_resolution": "State explicitly whether specflow-install, specflow-init, and any template/ changes are part of this issue. If they are deferred, reconcile that with the issue text and adjust acceptance criteria accordingly.",
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "origin_round": 1,
      "latest_round": 1,
      "notes": ""
    },
    {
      "id": "R1-F02",
      "severity": "medium",
      "category": "ambiguity",
      "file": "spec.md",
      "title": "Canonical current-truth specs are not defined",
      "detail": "The issue's core model separates current truth in openspec/specs/ from change records in openspec/changes/, and explicitly asks which existing specs/00x-* entries should become canonical capability specs versus historical changes. The spec sends all existing entries to openspec/changes/, but FR-002 still requires canonical capability specs and the spec never identifies any. It is unclear whether openspec/specs/ is intentionally empty after cutover or whether new current-truth specs must be authored during migration.",
      "suggested_resolution": "Specify what capability specs must exist immediately after migration, or explicitly state that openspec/specs/ will start empty and why that still satisfies the migration goal.",
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "origin_round": 1,
      "latest_round": 1,
      "notes": ""
    },
    {
      "id": "R1-F03",
      "severity": "high",
      "category": "completeness",
      "file": "spec.md",
      "title": "Historical change-record migration format is underspecified",
      "detail": "All legacy specs/ entries are to be migrated into openspec/changes/<change-id>/, but the spec does not define the required file structure or content mapping for those migrated records. The issue's target structure shows proposal.md, design.md, tasks.md, and spec deltas, while FR-003 only guarantees proposal.md. Without a defined minimum layout and mapping rule, implementers cannot know how to convert each legacy spec and reviewers cannot verify that the migration is correct.",
      "suggested_resolution": "Define the canonical layout for migrated historical records, including mandatory files, change-id naming, and how legacy content is transformed or preserved.",
      "status": "new",
      "relation": "new",
      "supersedes": null,
      "origin_round": 1,
      "latest_round": 1,
      "notes": ""
    }
  ],
