{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(gh auth status)",
      "Bash(gh issue view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh repo view:*)",
      "Bash(specflow-fetch-issue:*)",
      "Bash(source .specflow/config.env)",
      "Bash(ls .specflow/*)",
      "Bash(ls .specify/*)",
      "mcp__codex__*"
    ]
  }
}
