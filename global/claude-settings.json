{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(gh auth status)",
      "Bash(gh issue view:*)",
      "Bash(specflow-fetch-issue:*)",
      "Bash(specflow-parse-jsonl.py:*)",
      "Bash(codex exec:*)",
      "Bash(source .specflow/config.env)",
      "Bash(command -v codex)",
      "Bash(ls .specflow/*)",
      "Bash(ls .specify/*)",
      "Bash(mkdir -p .specflow/state/*)",
      "Bash(date:*)"
    ]
  },
  "env": {
    "GITHUB_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
  }
}
