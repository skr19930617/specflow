{
	"name": "specflow-node",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node dist/build.js",
		"check": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage && npm run validate:contracts",
		"compile": "tsc -p tsconfig.json",
		"coverage:badge": "node scripts/update-coverage-badge.js",
		"format": "biome format . --write && prettier --write \"**/*.{md,yaml,yml}\"",
		"format:check": "biome check . --formatter-enabled=true --linter-enabled=false --assist-enabled=false && prettier --check \"**/*.{md,yaml,yml}\"",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"test:coverage": "npm run build && c8 --clean --all --src dist --exclude \"dist/tests/**\" --exclude \"dist/build.js\" --reporter text-summary --reporter json-summary --reporter lcov -- node --test dist/tests/*.test.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"validate:contracts": "tsc -p tsconfig.json && node dist/validate.js",
		"test": "npm run build && node --test dist/tests/*.test.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/node": "^25.5.2",
		"c8": "^11.0.0",
		"prettier": "^3.8.1",
		"typescript": "^5.6.0"
	}
}
