#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="$HOME/.config/specflow"

# --- フラグ解析 ---
UPDATE_MODE=false
for arg in "$@"; do
  case "$arg" in
    --update) UPDATE_MODE=true ;;
    -h|--help)
      echo "Usage: specflow-init [--update]"
      echo
      echo "  (default)   Initialize .specflow/, .mcp.json, CLAUDE.md and install slash commands"
      echo "  --update    Force-update ~/.claude/commands/specflow*.md only"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: specflow-init [--update]"
      exit 1
      ;;
  esac
done

# --- インストール済みチェック ---
if [[ ! -d "$CONFIG_DIR/template" ]]; then
  echo "Error: specflow is not installed."
  echo "Run 'specflow-install' first (from the specflow repository)."
  exit 1
fi

# --- プロジェクトルート ---
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"

# --- --update モード: コマンドだけ更新して終了 ---
if [[ "$UPDATE_MODE" == true ]]; then
  GLOBAL_DIR="$CONFIG_DIR/global"
  if [[ ! -d "$GLOBAL_DIR" ]]; then
    echo "Error: global/ not found at $GLOBAL_DIR"
    echo "Run 'specflow-install' to update."
    exit 1
  fi
  mkdir -p "$HOME/.claude/commands"
  for cmd_file in "$GLOBAL_DIR"/specflow*.md; do
    [[ -f "$cmd_file" ]] || continue
    base="$(basename "$cmd_file")"
    cp "$cmd_file" "$HOME/.claude/commands/$base"
    echo "Updated ~/.claude/commands/$base"
  done
  # .specflow/ に不足しているプロンプトファイルを補完
  TEMPLATE_SPECFLOW="$CONFIG_DIR/template/.specflow"
  if [[ -d ".specflow" ]] && [[ -d "$TEMPLATE_SPECFLOW" ]]; then
    SYNCED=0
    for tmpl_file in "$TEMPLATE_SPECFLOW"/*.txt; do
      [[ -f "$tmpl_file" ]] || continue
      base="$(basename "$tmpl_file")"
      if [[ ! -f ".specflow/$base" ]]; then
        cp "$tmpl_file" ".specflow/$base"
        echo "Synced missing .specflow/$base"
        SYNCED=$((SYNCED + 1))
      fi
    done
    if [[ "$SYNCED" -gt 0 ]]; then
      echo "Synced $SYNCED missing prompt file(s) to .specflow/"
    fi
  fi
  echo "Done. Slash commands updated."
  exit 0
fi

# --- 初回セットアップ ---
if [[ -d ".specflow" ]]; then
  echo ".specflow/ already exists in $ROOT"
  echo "Use --update to refresh slash commands only."
  exit 1
fi

# --- テンプレート取得 ---
TEMPLATE_DIR=""

if [[ -n "${SPECFLOW_TEMPLATE_REPO:-}" ]]; then
  # 外部テンプレートリポジトリからクローン
  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' EXIT

  echo "Fetching template from $SPECFLOW_TEMPLATE_REPO..."
  if ! gh repo clone "$SPECFLOW_TEMPLATE_REPO" "$TMPDIR/template" -- --depth 1 2>/dev/null; then
    echo "Failed to clone template repo: $SPECFLOW_TEMPLATE_REPO"
    echo
    echo "Ensure:"
    echo "  1. gh auth login is done"
    echo "  2. SPECFLOW_TEMPLATE_REPO is set correctly"
    echo
    echo "Current value: $SPECFLOW_TEMPLATE_REPO"
    exit 1
  fi
  TEMPLATE_DIR="$TMPDIR/template"
else
  # インストール済みテンプレートを使用
  TEMPLATE_DIR="$CONFIG_DIR/template"
fi

# テンプレート検証
if [[ ! -d "$TEMPLATE_DIR/.specflow" ]]; then
  echo "Error: .specflow/ not found in template ($TEMPLATE_DIR)"
  exit 1
fi

# --- ファイルコピー ---

# .specflow/
cp -R "$TEMPLATE_DIR/.specflow" .specflow
echo "Created .specflow/"

# .mcp.json
if [[ ! -f ".mcp.json" ]]; then
  if [[ -f "$TEMPLATE_DIR/.mcp.json" ]]; then
    cp "$TEMPLATE_DIR/.mcp.json" .mcp.json
    echo "Created .mcp.json"
  fi
else
  echo ".mcp.json already exists, skipped"
fi

# CLAUDE.md
if [[ ! -f "CLAUDE.md" ]]; then
  if [[ -f "$TEMPLATE_DIR/CLAUDE.md" ]]; then
    cp "$TEMPLATE_DIR/CLAUDE.md" CLAUDE.md
    echo "Created CLAUDE.md — edit to match your project"
  fi
else
  echo "CLAUDE.md already exists, skipped"
fi

# openspec/ directory structure
if [[ ! -d "openspec" ]]; then
  mkdir -p openspec/specs openspec/changes
  if [[ -f "$TEMPLATE_DIR/openspec/README.md" ]]; then
    cp "$TEMPLATE_DIR/openspec/README.md" openspec/README.md
  fi
  echo "Created openspec/ (specs/, changes/, README.md)"
else
  # Ensure subdirectories exist even if openspec/ already exists
  mkdir -p openspec/specs openspec/changes
  echo "openspec/ already exists, ensured subdirectories"
fi

# --- スラッシュコマンドのインストール ---
GLOBAL_DIR="$CONFIG_DIR/global"
if [[ -d "$GLOBAL_DIR" ]]; then
  mkdir -p "$HOME/.claude/commands"
  for cmd_file in "$GLOBAL_DIR"/specflow*.md; do
    [[ -f "$cmd_file" ]] || continue
    base="$(basename "$cmd_file")"
    if [[ ! -f "$HOME/.claude/commands/$base" ]]; then
      cp "$cmd_file" "$HOME/.claude/commands/$base"
      echo "Installed ~/.claude/commands/$base"
    fi
  done
fi

echo
echo "Initialized .specflow/ in $ROOT"
echo "  .specflow/config.env"
echo

# specflow prerequisites チェック
if [[ ! -d ".specify" ]]; then
  echo "Warning: specflow prerequisites (.specify/) not found."
  echo "  /specflow requires .specify/ directory. Install it first."
  echo "  See: https://github.com/bdobbs-amd/specify"
  echo
fi

echo "Next steps:"
if [[ ! -d ".specify" ]]; then
  echo "  0. Install specflow prerequisites (.specify/)"
fi
echo "  1. Edit CLAUDE.md — fill in Tech Stack, Commands, Code Style"
echo "  2. Edit .specflow/config.env — add project-specific env vars if needed"
echo "  3. Ensure Codex CLI is installed (npm install -g @openai/codex)"
