#!/usr/bin/env bash
set -euo pipefail

# テンプレートリポジトリの設定
# 環境変数 SPECFLOW_TEMPLATE_REPO で上書き可能
DEFAULT_TEMPLATE_REPO="skr19930617/specflow-template"
TEMPLATE_REPO="${SPECFLOW_TEMPLATE_REPO:-$DEFAULT_TEMPLATE_REPO}"

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"

if [[ -d ".specflow" ]]; then
  echo ".specflow/ already exists in $ROOT"
  exit 1
fi

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

echo "Fetching template from $TEMPLATE_REPO..."

# gh repo clone でテンプレートを取得（shallow clone）
if ! gh repo clone "$TEMPLATE_REPO" "$TMPDIR/template" -- --depth 1 2>/dev/null; then
  echo "Failed to clone template repo: $TEMPLATE_REPO"
  echo
  echo "Ensure:"
  echo "  1. gh auth login is done"
  echo "  2. SPECFLOW_TEMPLATE_REPO is set correctly (or edit DEFAULT_TEMPLATE_REPO in this script)"
  echo
  echo "Current value: $TEMPLATE_REPO"
  exit 1
fi

# Copy .specflow/ from template
cp -R "$TMPDIR/template/.specflow" .specflow

# Copy .mcp.json if not present (OpenAI MCP server config)
if [[ ! -f ".mcp.json" ]]; then
  if [[ -f "$TMPDIR/template/.mcp.json" ]]; then
    cp "$TMPDIR/template/.mcp.json" .mcp.json
    echo "Created .mcp.json — OpenAI MCP server configured"
  fi
else
  echo ".mcp.json already exists, skipped"
fi

# Copy CLAUDE.md if not present
if [[ ! -f "CLAUDE.md" ]]; then
  cp "$TMPDIR/template/CLAUDE.md" CLAUDE.md
  echo "Created CLAUDE.md — edit to match your project"
else
  echo "CLAUDE.md already exists, skipped"
fi

# Install /specflow slash commands to ~/.claude/commands/
GLOBAL_DIR="$(cd "$(dirname "$0")/../global" && pwd)"
if [[ -d "$GLOBAL_DIR" ]]; then
  mkdir -p "$HOME/.claude/commands"
  for cmd_file in "$GLOBAL_DIR"/specflow*.md; do
    base="$(basename "$cmd_file")"
    if [[ ! -f "$HOME/.claude/commands/$base" ]]; then
      cp "$cmd_file" "$HOME/.claude/commands/$base"
      echo "Installed /$base → ~/.claude/commands/$base"
    fi
  done
fi

echo "Initialized .specflow/ in $ROOT"
echo "  .specflow/config.env"
echo "  .specflow/review_spec_prompt.txt"
echo "  .specflow/review_impl_prompt.txt"
echo

# Check if speckit (.specify/) is installed
if [[ ! -d ".specify" ]]; then
  echo "⚠  speckit (.specify/) が見つかりません。"
  echo "   /specflow は speckit を前提としています。"
  echo "   speckit をインストールしてから /specflow を使用してください。"
  echo "   参考: https://github.com/bdobbs-amd/specify"
  echo
fi

echo "Next steps:"
if [[ ! -d ".specify" ]]; then
  echo "  0. Install speckit — /specflow requires speckit (.specify/) to be set up"
fi
echo "  1. Edit CLAUDE.md — fill in Tech Stack, Commands, Code Style"
echo "  2. Edit .specflow/config.env — add project-specific env vars if needed"
echo "  3. Optionally customize .specflow/review_*_prompt.txt"
echo "  4. Set OPENAI_API_KEY env var and add mcpServers to ~/.claude/settings.json"
echo "     (see global/claude-settings.json for reference)"
