#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ $# -lt 1 ]]; then
  echo "Usage: specflow <issue-url>"
  exit 1
fi

INPUT="$1"
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"

if [[ ! -f ".specflow/config.env" ]]; then
  echo "Missing .specflow/config.env — run specflow-init first"
  exit 1
fi

source .specflow/config.env
mkdir -p .specflow/state

timestamp="$(date +%Y%m%d-%H%M%S)"
run_dir=".specflow/state/$timestamp"
mkdir -p "$run_dir"

ISSUE_JSON="$run_dir/issue.json"
SPEC_FILE="$run_dir/spec.md"
SPEC_REVIEW_JSONL="$run_dir/spec-review.jsonl"
SPEC_REVIEW_JSON="$run_dir/spec-review.json"
IMPL_REVIEW_JSONL="$run_dir/impl-review.jsonl"
IMPL_REVIEW_JSON="$run_dir/impl-review.json"

echo "[1/8] Fetching issue..."
"$SCRIPT_DIR/specflow-fetch-issue" "$INPUT" > "$ISSUE_JSON"

echo "[2/8] Building spec from issue..."
python3 - "$ISSUE_JSON" "$SPEC_FILE" <<'PY'
import json, sys

issue_path, spec_path = sys.argv[1], sys.argv[2]
with open(issue_path, "r", encoding="utf-8") as f:
    data = json.load(f)

title = data.get("title", "").strip()
body = data.get("body", "").strip()
url = data.get("url", "").strip()
number = data.get("number")
state = data.get("state", "")
author = (data.get("author") or {}).get("login", "")
labels = [x.get("name") for x in (data.get("labels") or []) if x.get("name")]

spec = f"""# Spec Seed from GitHub Issue

- Source URL: {url}
- Issue Number: {number}
- Title: {title}
- Author: {author}
- State: {state}
- Labels: {", ".join(labels)}

## Original Issue Body

{body}

## Clarification Notes

<!-- Claude will refine this section -->

## Acceptance Criteria

<!-- Claude will refine this section -->
"""

with open(spec_path, "w", encoding="utf-8") as f:
    f.write(spec)
PY

echo "[3/8] Claude clarify..."
SPEC_CONTENT="$(cat "$SPEC_FILE")"
claude -p "You are refining a spec draft derived from a GitHub issue. Improve clarity, identify missing assumptions, and rewrite the spec in-place conceptually. Here is the current spec draft:\n\n$SPEC_CONTENT"

echo "[4/8] Codex reviews the spec..."
SPEC_PROMPT="$(cat .specflow/review_spec_prompt.txt)"
{
  printf "%s\n\n" "$SPEC_PROMPT"
  printf "SPEC CONTENT:\n"
  cat "$SPEC_FILE"
} | codex exec --json > "$SPEC_REVIEW_JSONL"

python3 "$SCRIPT_DIR/specflow-parse-jsonl.py" "$SPEC_REVIEW_JSONL" > "$SPEC_REVIEW_JSON"

echo
echo "=== SPEC REVIEW ==="
cat "$SPEC_REVIEW_JSON"
echo

SPEC_DECISION="$(python3 - <<'PY' "$SPEC_REVIEW_JSON"
import json,sys
with open(sys.argv[1], encoding="utf-8") as f:
    data=json.load(f)
print(data.get("decision","REQUEST_CHANGES"))
PY
)"

if [[ "$SPEC_DECISION" != "APPROVE" ]]; then
  echo "[5/8] Claude resolves spec review findings..."
  REVIEW_TEXT="$(cat "$SPEC_REVIEW_JSON")"
  claude -p "Resolve these spec review findings while preserving the intent of the issue. Review JSON:\n$REVIEW_TEXT"
else
  echo "[5/8] Spec approved."
fi

echo "[6/8] Claude plan/tasks..."
claude -p "/speckit.plan"
claude -p "/speckit.tasks"

echo "[7/8] Claude implement..."
claude -p "Implement the active tasks. Stop when ready for review."

echo "[8/8] Codex reviews implementation..."
IMPL_PROMPT="$(cat .specflow/review_impl_prompt.txt)"
{
  printf "%s\n\n" "$IMPL_PROMPT"
  printf "CURRENT GIT DIFF:\n"
  git diff -- . ':(exclude).specflow'
  printf "\n\nSPEC CONTENT:\n"
  cat "$SPEC_FILE"
} | codex exec --json > "$IMPL_REVIEW_JSONL"

python3 "$SCRIPT_DIR/specflow-parse-jsonl.py" "$IMPL_REVIEW_JSONL" > "$IMPL_REVIEW_JSON"

echo
echo "=== IMPLEMENTATION REVIEW ==="
cat "$IMPL_REVIEW_JSON"
echo
echo "Choose one:"
echo "  1) approve"
echo "  2) fix"
echo "  3) reject"
echo "  4) change-spec"
read -r choice

case "$choice" in
  1)
    echo "Approved."
    ;;
  2)
    REVIEW_TEXT="$(cat "$IMPL_REVIEW_JSON")"
    claude -p "Apply only the human-approved findings from this implementation review JSON and stop for re-review:\n$REVIEW_TEXT"
    ;;
  3)
    echo "Rejected."
    ;;
  4)
    claude -p "Revise the spec based on new human feedback, then re-run clarify/plan/tasks as needed."
    ;;
  *)
    echo "Invalid choice"
    exit 1
    ;;
esac
