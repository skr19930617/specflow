#!/usr/bin/env bash
# specflow-create-sub-issues — Create GitHub sub-issues from a decomposition plan
#
# Reads a JSON payload from stdin describing sub-features to create as GitHub issues.
# Creates phase labels, issues with phase-prefixed titles, and a summary comment
# on the parent issue. Supports idempotent retry via decomposition ID markers.
#
# Usage:
#   echo '<json>' | specflow-create-sub-issues
#   cat payload.json | specflow-create-sub-issues
#
# Input (stdin): JSON matching the Data Contract input schema (see plan.md)
# Output (stdout): JSON matching the Data Contract output schema (see plan.md)
# Exit codes:
#   0 — all issues created successfully
#   1 — input validation error or fatal error
#   2 — partial failure (some issues created, some failed)

set -euo pipefail

# --- Help ---
show_help() {
  cat <<'EOF'
Usage: specflow-create-sub-issues < payload.json

Create GitHub sub-issues from a decomposition plan.

Reads JSON from stdin with fields:
  parent_issue_number  (int)    Parent issue number
  repo                 (string) Repository in "owner/repo" format
  run_timestamp        (string) Unique run identifier (YYYYMMDD-HHMMSS)
  sub_features         (array)  Sub-features to create as issues

Each sub_feature must have:
  phase_number, title, description, requirements, acceptance_criteria, phase_total

Output: JSON with created[], failed[], summary_comment_posted, parent_issue_number
EOF
  exit 0
}

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && show_help

# --- Read stdin ---
INPUT="$(cat)"

if [[ -z "$INPUT" ]]; then
  echo '{"error":"No input provided on stdin"}' >&2
  exit 1
fi

# --- Save input to temp file for safe Python access ---
INPUT_FILE="$(mktemp)"
echo "$INPUT" > "$INPUT_FILE"
trap 'rm -f "$INPUT_FILE"' EXIT

# --- Input validation (T003) ---
validation_result="$(python3 <<PY
import json, sys

with open("$INPUT_FILE") as f:
    try:
        data = json.load(f)
    except json.JSONDecodeError as e:
        print(json.dumps({"error": f"Invalid JSON: {e}"}))
        sys.exit(1)

errors = []

for field in ["parent_issue_number", "repo", "run_timestamp", "sub_features"]:
    if field not in data:
        errors.append(f"Missing required field: {field}")

if "sub_features" in data:
    if not isinstance(data["sub_features"], list) or len(data["sub_features"]) == 0:
        errors.append("sub_features must be a non-empty array")
    else:
        for i, sf in enumerate(data["sub_features"]):
            for sf_field in ["phase_number", "title", "description", "requirements", "acceptance_criteria", "phase_total"]:
                if sf_field not in sf:
                    errors.append(f"sub_features[{i}]: missing required field: {sf_field}")

if errors:
    print(json.dumps({"error": "Validation failed", "details": errors}))
    sys.exit(1)

print("OK")
PY
)" || true

if [[ "$validation_result" != "OK" ]]; then
  echo "$validation_result" >&2
  exit 1
fi

# --- Parse input fields via Python reading from file (safe from quoting issues) ---
eval "$(python3 <<PY
import json
with open("$INPUT_FILE") as f:
    data = json.load(f)
# Output shell-safe variable assignments
print(f"PARENT_ISSUE={data['parent_issue_number']}")
# Quote repo safely
repo = data['repo'].replace("'", "'\\''")
print(f"REPO='{repo}'")
ts = data['run_timestamp'].replace("'", "'\\''")
print(f"RUN_TIMESTAMP='{ts}'")
print(f"SUB_FEATURES_COUNT={len(data['sub_features'])}")
PY
)"

# --- Phase label colors ---
LABEL_COLORS=("0e8a16" "1d76db" "d93f0b" "5319e7" "fbca04" "b60205" "006b75" "e99695")

# --- Create phase labels upfront (T005) ---
for i in $(seq 0 $((SUB_FEATURES_COUNT - 1))); do
  phase_num="$(python3 -c "import json; data=json.load(open('$INPUT_FILE')); print(data['sub_features'][$i]['phase_number'])")"
  color_idx=$(( (phase_num - 1) % ${#LABEL_COLORS[@]} ))
  gh label create "phase-${phase_num}" \
    --repo "$REPO" \
    --color "${LABEL_COLORS[$color_idx]}" \
    --description "Decomposition phase ${phase_num}" \
    --force 2>/dev/null || true
done

# --- Create issues sequentially (T004 + T006) ---
# Use a Python script for the entire issue creation loop to avoid shell quoting issues
RESULT_FILE="$(mktemp)"

# Disable set -e for the Python call — it may exit with code 2 (partial failure)
# and we need to capture the exit code and output the result JSON
set +e
python3 - "$INPUT_FILE" "$REPO" "$PARENT_ISSUE" "$RUN_TIMESTAMP" "$RESULT_FILE" <<'ISSUE_CREATOR'
import json, subprocess, sys, os

input_file = sys.argv[1]
repo = sys.argv[2]
parent_issue = int(sys.argv[3])
run_timestamp = sys.argv[4]
result_file = sys.argv[5]

with open(input_file) as f:
    data = json.load(f)

created = []
failed = []

for sf in data["sub_features"]:
    phase_num = sf["phase_number"]
    title = sf["title"]
    description = sf["description"]
    phase_total = sf["phase_total"]
    requirements = sf["requirements"]
    acceptance_criteria = sf["acceptance_criteria"]

    issue_title = f"Phase {phase_num}: {title}"
    decomposition_id = f"decompose-{parent_issue}-{run_timestamp}-phase-{phase_num}"

    # --- Idempotent duplicate guard (T004) ---
    try:
        result = subprocess.run(
            ["gh", "issue", "list", "--repo", repo, "--search", decomposition_id,
             "--json", "number,url,title", "--limit", "1"],
            capture_output=True, text=True, timeout=30
        )
        existing = json.loads(result.stdout) if result.returncode == 0 else []
    except Exception:
        existing = []

    if existing:
        created.append({
            "phase_number": phase_num,
            "issue_number": existing[0]["number"],
            "issue_url": existing[0]["url"],
            "title": issue_title
        })
        continue

    # --- Render issue body (FR-009 template) ---
    req_lines = "\n".join(f"- {r}" for r in requirements)
    ac_lines = "\n".join(f"- {c}" for c in acceptance_criteria)
    issue_body = f"""## Phase {phase_num} of {phase_total}: {title}

**Parent Issue**: #{parent_issue}
**Decomposition ID**: {decomposition_id}

## Description
{description}

## Requirements
{req_lines}

## Acceptance Criteria
{ac_lines}"""

    # --- Create issue (T006) ---
    try:
        result = subprocess.run(
            ["gh", "issue", "create", "--repo", repo,
             "--title", issue_title, "--body", issue_body,
             "--label", f"phase-{phase_num}"],
            capture_output=True, text=True, timeout=60
        )
        if result.returncode == 0:
            issue_url = result.stdout.strip().split("\n")[-1]
            # Extract issue number from URL
            issue_number = int(issue_url.rstrip("/").split("/")[-1])
            created.append({
                "phase_number": phase_num,
                "issue_number": issue_number,
                "issue_url": issue_url,
                "title": issue_title
            })
        else:
            error_msg = (result.stderr or result.stdout or "Unknown error").strip()[:200]
            failed.append({
                "phase_number": phase_num,
                "title": issue_title,
                "error": error_msg
            })
    except Exception as e:
        failed.append({
            "phase_number": phase_num,
            "title": issue_title,
            "error": str(e)[:200]
        })

# --- Post summary comment on parent issue (T007) ---
# skip_comment flag allows the caller to suppress auto-comment on retry runs
# so the slash command can post a consolidated comment instead
skip_comment = data.get("skip_comment", False)
summary_posted = False
if created and not skip_comment:
    sorted_created = sorted(created, key=lambda x: x["phase_number"])
    lines = [f"- **Phase {c['phase_number']}**: #{c['issue_number']} — {c['title']}" for c in sorted_created]
    comment_body = f"""## Decomposition Sub-Issues

This issue has been decomposed into the following sub-issues:

{chr(10).join(lines)}

_Decomposition run: {run_timestamp}_"""

    try:
        result = subprocess.run(
            ["gh", "issue", "comment", str(parent_issue),
             "--repo", repo, "--body", comment_body],
            capture_output=True, text=True, timeout=30
        )
        summary_posted = result.returncode == 0
    except Exception:
        summary_posted = False

# --- Output JSON result (T008) ---
output = {
    "created": created,
    "failed": failed,
    "summary_comment_posted": summary_posted,
    "parent_issue_number": parent_issue
}

with open(result_file, "w") as f:
    json.dump(output, f, indent=2)

# Exit code
sys.exit(2 if failed else 0)
ISSUE_CREATOR

ISSUE_EXIT_CODE=$?
set -e

# Output result JSON to stdout
cat "$RESULT_FILE"
rm -f "$RESULT_FILE"

exit $ISSUE_EXIT_CODE
