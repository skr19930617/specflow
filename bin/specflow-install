#!/usr/bin/env bash
set -euo pipefail

# --- symlink を辿ってスクリプトの実体パスを解決 ---
resolve_symlink() {
  local source="$1"
  while [[ -L "$source" ]]; do
    local dir="$(cd "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  echo "$source"
}

REAL_SCRIPT="$(resolve_symlink "$0")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

CONFIG_DIR="$HOME/.config/specflow"
TARGET_BIN="$HOME/bin"

echo "=== specflow install ==="
echo "Source: $REPO_ROOT"
echo

# -------------------------------------------------------
# 1. template/ と global/ を ~/.config/specflow/ にコピー
# -------------------------------------------------------
echo "--- assets → ~/.config/specflow/ ---"
mkdir -p "$CONFIG_DIR"

# template/
if [[ -d "$REPO_ROOT/template" ]]; then
  rm -rf "$CONFIG_DIR/template"
  cp -R "$REPO_ROOT/template" "$CONFIG_DIR/template"
  echo "  template/ → $CONFIG_DIR/template/"
else
  echo "  Warning: $REPO_ROOT/template/ not found, skipped"
fi

# global/
if [[ -d "$REPO_ROOT/global" ]]; then
  rm -rf "$CONFIG_DIR/global"
  cp -R "$REPO_ROOT/global" "$CONFIG_DIR/global"
  echo "  global/   → $CONFIG_DIR/global/"
else
  echo "  Warning: $REPO_ROOT/global/ not found, skipped"
fi

# -------------------------------------------------------
# 2. bin/ スクリプトを ~/bin にシンボリックリンク
# -------------------------------------------------------
echo
echo "--- bin/ scripts → ~/bin ---"
mkdir -p "$TARGET_BIN"

for script in "$REPO_ROOT/bin"/specflow-*; do
  base="$(basename "$script")"
  ln -sf "$script" "$TARGET_BIN/$base"
  echo "  $base"
done

# ~/bin が PATH に入っているか確認
if ! echo "$PATH" | tr ':' '\n' | grep -qx "$TARGET_BIN"; then
  echo
  echo "  Warning: $TARGET_BIN is not in PATH."
  CURRENT_SHELL="$(basename "${SHELL:-bash}")"
  case "$CURRENT_SHELL" in
    fish)
      echo "  Add to ~/.config/fish/config.fish:"
      echo "    set -gx fish_user_paths ~/bin \$fish_user_paths"
      ;;
    *)
      echo "  Add to ~/.${CURRENT_SHELL}rc:"
      echo "    export PATH=\"\$HOME/bin:\$PATH\""
      ;;
  esac
fi

# -------------------------------------------------------
# 3. スラッシュコマンドを ~/.claude/commands/ にコピー
# -------------------------------------------------------
echo
echo "--- slash commands → ~/.claude/commands/ ---"
mkdir -p "$HOME/.claude/commands"

for cmd_file in "$CONFIG_DIR/global"/specflow*.md; do
  [[ -f "$cmd_file" ]] || continue
  base="$(basename "$cmd_file")"
  cp "$cmd_file" "$HOME/.claude/commands/$base"
  echo "  $base"
done

# -------------------------------------------------------
# 4. claude-settings.json の権限を ~/.claude/settings.json にマージ
# -------------------------------------------------------

SETTINGS_DST="$HOME/.claude/settings.json"

echo
echo "--- permissions → ~/.claude/settings.json ---"

SETTINGS_SRC="$CONFIG_DIR/global/claude-settings.json"

if [[ ! -f "$SETTINGS_SRC" ]]; then
  echo "  Warning: $SETTINGS_SRC not found, skipped"
elif ! command -v jq &>/dev/null; then
  echo "  Warning: jq not found. Skipping settings merge."
  echo "  Manually merge $SETTINGS_SRC into $SETTINGS_DST"
else
  if [[ ! -f "$SETTINGS_DST" ]]; then
    mkdir -p "$(dirname "$SETTINGS_DST")"
    cp "$SETTINGS_SRC" "$SETTINGS_DST"
    echo "  Created $SETTINGS_DST"
  else
    TMPFILE="$(mktemp)"
    cp "$SETTINGS_DST" "$TMPFILE"

    # --- permissions マージ ---
    ADDED=0
    SKIPPED=0

    while IFS= read -r perm; do
      if jq -e --arg p "$perm" '.permissions.allow | index($p) != null' "$TMPFILE" &>/dev/null; then
        SKIPPED=$((SKIPPED + 1))
      else
        jq --arg p "$perm" '.permissions.allow += [$p]' "$TMPFILE" > "${TMPFILE}.new"
        mv "${TMPFILE}.new" "$TMPFILE"
        ADDED=$((ADDED + 1))
        echo "  + $perm"
      fi
    done < <(jq -r '.permissions.allow[]' "$SETTINGS_SRC")

    if [[ "$ADDED" -gt 0 ]]; then
      echo "  Added $ADDED permissions ($SKIPPED already present)"
    else
      echo "  All permissions already present ($SKIPPED)"
    fi

    cp "$TMPFILE" "$SETTINGS_DST"
    rm -f "$TMPFILE" "${TMPFILE}.new"
  fi

fi

# -------------------------------------------------------
# 完了
# -------------------------------------------------------
echo
echo "Done!"
echo
echo "Next: run 'specflow-init' in your project directory to initialize .specflow/"
