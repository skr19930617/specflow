#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: specflow-fetch-issue <issue-url>"
  exit 1
fi

ISSUE_URL="$1"

# GitHub issue URL:
# https://github.com/OWNER/REPO/issues/123
# https://HOST/OWNER/REPO/issues/123

parsed="$(python3 - "$ISSUE_URL" <<'PY'
import re, sys
url = sys.argv[1].strip()
m = re.match(r'^https://([^/]+)/([^/]+)/([^/]+)/issues/([0-9]+)(?:/.*)?$', url)
if not m:
    print("INVALID")
    sys.exit(0)
host, owner, repo, number = m.groups()
print(host)
print(owner)
print(repo)
print(number)
PY
)"

if [[ "$parsed" == "INVALID" ]]; then
  echo "Invalid GitHub issue URL: $ISSUE_URL"
  exit 1
fi

HOST="$(echo "$parsed" | sed -n '1p')"
OWNER="$(echo "$parsed" | sed -n '2p')"
REPO="$(echo "$parsed" | sed -n '3p')"
NUMBER="$(echo "$parsed" | sed -n '4p')"

# GitHub.com 以外なら GH_HOST を指定
if [[ "$HOST" != "github.com" ]]; then
  export GH_HOST="$HOST"
fi

# issue本文を JSON で取得
gh issue view "$NUMBER" \
  --repo "$OWNER/$REPO" \
  --json number,title,body,url,labels,assignees,author,state
